# =============================================================================
# DESARROLLO: copiar como .env.local y rellenar con valores de cada entorno
# Para sincronizar local desde Vercel: vercel env pull .env.local
# =============================================================================

# URL del App (TalentoYa-App) — usada en CTAs y links de la landing
# local:   http://localhost:3000 (App corre en 3000, Landing en 3001)
# staging: https://develop.talentoya-app.vercel.app
# prod:    https://app.talentoya.co
NEXT_PUBLIC_TALENTOYA_APP_URL=http://localhost:3000

# Supabase — captura de leads (tabla "leads") desde el modal de planes
# Tomar de Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# service_role: BYPASSA RLS — solo servidor, nunca exponer al cliente.
# En Vercel marcar como secreta (NO usar prefijo NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=
